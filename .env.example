# ---------------------------------------------------------------
# Divi 5 Deterministic Validator — environment variables
# Copy this file to .env and adjust values. Do NOT commit .env.
# bootstrap.sh creates .env from this file automatically if missing.
# ---------------------------------------------------------------

# WordPress site
WP_SITE_URL=http://localhost:8181
WP_SITE_TITLE="Divi5 Validator Dev"
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@example.local

# Database (MariaDB)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
MYSQL_PASSWORD=wppassword

# WordPress DB connection (must match above)
WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wpuser
WORDPRESS_DB_PASSWORD=wppassword

# Port exposed on localhost
WP_PORT=8181
