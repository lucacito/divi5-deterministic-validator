{
    "name": "jhmg/divi5-deterministic-validator",
    "description": "Deterministic validator for Divi 5 layout JSON — pure PHP, no AI.",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "Divi5Validator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Divi5Validator\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
